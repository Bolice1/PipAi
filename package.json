{
  "name": "pipai",
  "version": "1.0.0",
  "description": "This is a lightweight multi-agent AI system where three specialized agents collaborate in a pipeline to produce accurate, structured, and efficient outputs.",
  "main": "src/server.ts",
  "scripts": {
    "build:server": "tsc -p tsconfig.json",
    "build:ui": "node scripts/build-ui.mjs",
    "dev": "npm run build:ui && ts-node --transpile-only src/server.ts",
    "start": "npm run build:ui && ts-node --transpile-only src/server.ts",
    "build": "npm run build:server && npm run build:ui",
    "test": "node --test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bolice1/PipAI.git"
  },
  "keywords": [
    "orchestrator",
    "AI",
    "multi-agent"
  ],
  "author": "KOMEZUSENGE Bolice",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Bolice1/PipAI/issues"
  },
  "homepage": "https://github.com/Bolice1/PipAI#readme",
  "dependencies": {
    "express": "^5.2.1",
    "mongoose": "^9.4.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "esbuild": "^0.25.11"
  }
}
